{
	"version": "0.2.0",
	"configurations": [
		{
			"type": "node",
			"request": "launch",
			"name": "Debug Server (ESM + TS)",
			"program": "${workspaceFolder}/server/server.js",
			"cwd": "${workspaceFolder}",
			"runtimeExecutable": "node",
			"runtimeArgs": [
				"--inspect",
				"--enable-source-maps"
			],
			"outFiles": [
				"${workspaceFolder}/server/**/*.js"
			],
			"sourceMaps": true,
			"skipFiles": [
				"<node_internals>/**"
			]
		}
	]
}