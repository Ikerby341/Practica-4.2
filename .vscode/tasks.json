{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Build Public",
			"type": "shell",
			"command": "tsc -p srcPublic/tsconfig.json",
			"problemMatcher": "$tsc"
		},
		{
			"label": "Build Server",
			"type": "shell",
			"command": "tsc -p srcServer/tsconfig.json",
			"problemMatcher": "$tsc"
		},
		{
			"label": "Build Public & Server",
			"dependsOn": ["Build Public", "Build Server"],
			"dependsOrder": "sequence",
			"group": {
				"kind": "build"
			}
		}
	]
}
  